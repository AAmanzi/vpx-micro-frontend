{
  "name": "vpx-micro-frontend",
  "version": "1.0.0",
  "main": "main.js",
  "repository": "git@github.com:AAmanzi/visual-pinball-micro-frontend.git",
  "license": "MIT",
  "scripts": {
    "dev:electron": "npm run build:preload && nodemon",
    "dev:next": "npm run build:preload && next dev",
    "dev:mock": "DEV_MOCK=1 npm run dev:electron",
    "dev": "yarn dev:electron",
    "logs": "powershell \"Get-Content -Path backend.log -Wait\"",
    "build:preload": "esbuild src/electron/preload.ts --bundle --platform=node --external:electron --outfile=src/electron/preload.js --format=cjs",
    "build:next": "next build",
    "start:next": "next start",
    "vpx:cgamename": "node scripts/vpx-cgamename.js",
    "db:reset": "electron scripts/reset-db.js"
  },
  "dependencies": {
    "cfb": "^1.2.2",
    "classnames": "^2.5.1",
    "electron-store": "^8.1.0",
    "next": "^16.1.6",
    "prettier": "^3.2.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sass": "^1.72.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/node": "^20.8.4",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^40.4.0",
    "esbuild": "^0.19.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.2.2"
  }
}
